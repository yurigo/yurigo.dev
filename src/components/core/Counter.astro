---
import Pacman from "../icons/Pacman.astro";
---

<div
  id="eat-counter"
  class="flex items-center gap-2 px-3 py-1 bg-black/30 rounded-full text-sm font-bold"
>
  <span class="text-amber-300">
    <Pacman color="yellow" />
  </span>
  <span id="counter-value" class="">0</span>
</div>

<script>
  const counterValue = document.getElementById("counter-value");
  const eatCounter = document.getElementById("eat-counter");

  document.addEventListener("mascotEatsCursor", (event: CustomEvent) => {
    if (counterValue) {
      counterValue.textContent = event.detail.count.toString();
    }

    // Trigger pulse animation
    if (eatCounter) {
      eatCounter.classList.add("eating");

      setTimeout(() => {
        eatCounter.classList.remove("eating");
      }, 400);
    }
  });
</script>

<style>
  #eat-counter {
    transition: transform 0.2s ease;
  }

  #eat-counter:hover {
    transform: scale(1.1);
  }

  #eat-counter.eating {
    animation: pulse-scale 0.4s ease-in-out;
  }

  @keyframes pulse-scale {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.2);
    }
  }
</style>
