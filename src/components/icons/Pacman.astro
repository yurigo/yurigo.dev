<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="currentColor"
  class="icon icon-tabler icons-tabler-filled icon-tabler-pacman"
  id="pacman-svg"
  ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
    d="M13.557 2.015a10 10 0 0 1 7.257 3.744a1 1 0 0 1 -.074 1.331l-4.912 4.91l4.912 4.91a1 1 0 0 1 .074 1.332a10 10 0 1 1 -15.112 -13.078l.235 -.242l.07 -.063a9.98 9.98 0 0 1 7.55 -2.844m-1.057 3.485c-1.02 0 -1.86 .762 -1.982 1.748l-.013 .15a1 1 0 0 0 -.005 .102a2 2 0 1 0 2 -2"
  ></path></svg
>

<script>
  const pacmanSvg = document.getElementById("pacman-svg");

  document.addEventListener("mascotEatsCursor", () => {
    if (pacmanSvg) {
      pacmanSvg.classList.add("munching");
      setTimeout(() => {
        pacmanSvg.classList.remove("munching");
      }, 1200);
    }
  });
</script>

<style>
  #pacman-svg.munching {
    animation: rotate-munch 0.4s ease-in-out infinite;
  }

  @keyframes rotate-munch {
    0%,
    100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-20deg);
    }
    75% {
      transform: rotate(20deg);
    }
  }
</style>
