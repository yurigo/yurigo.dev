---
import Layout from "../layouts/Layout.astro";
import Header from "@components/sections/Header.astro";
import Splash from "@components/sections/Splash.astro";
import AboutMe from "@components/sections/AboutMe.astro";

import Other from "@components/Other.astro";

import Resources from "@components/sections/Resources.astro";
import Footer from "@components/sections/Footer.astro";
---

<Layout>
  <Header />
  <main style="position: relative;">
    <Splash />
    <Other>
      <AboutMe />
    </Other>
    <Resources />
  </main>
  <Footer />
</Layout>

<style is:global>
  /* animate background-hue 0.5s linear; */

  @property --background-hue {
    syntax: "<number>";
    inherits: false;
    initial-value: 0;
  }

  /* @property --background-lightness {
    syntax: "<number>";
    inherits: false;
    initial-value: 50%;
  } */

  body {
    animation: rainbow-background-animation 10s linear infinite;

    background-color: oklch(
      var(--background-lightness) var(--background-saturation)
        var(--background-hue)
    );
  }

  @keyframes rainbow-background-animation {
    0% {
      --background-hue: 0;
    }
    100% {
      --background-hue: 360;
    }
  }
</style>

<script>
  // const root = document.querySelector(":root");
  // let hue = Math.floor(Math.random() * 360);
  // const changeBackgroundHUE = () => {
  //   hue = hue % 360; //reset please!
  //   root.style.setProperty("--background-hue", ++hue % 360);
  // };
  // setInterval(changeBackgroundHUE, 50);

  const eyeLeft = document.getElementById("eye_left");
  const eyeRight = document.getElementById("eye_right");
  const mustacheGroup = document.getElementById("mustache-group");
  const mascotContainer = document.getElementById("mascot_container");
  const FRONT_LOOK_TRANSFORM_LEFT = "translate(10px, -5px)";
  const FRONT_LOOK_TRANSFORM_RIGHT = "translate(-10px, -5px)";

  let eatCounter = 0;
  let isMunching = false;
  let isUpdatingEyes = false;

  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let targetOffsetX = 0;
  let targetOffsetY = 0;

  document.addEventListener("mousemove", (event) => {
    mouseX = event.clientX;
    mouseY = event.clientY;
    if (!isMunching) {
      changeEyesPosition(mouseX, mouseY);
    }
  });

  function touch(event) {
    if (!event.touches.length) {
      return;
    }

    mouseX = event.touches[0].clientX;
    mouseY = event.touches[0].clientY;
    if (!isMunching) {
      changeEyesPosition(mouseX, mouseY);
    }
  }

  document.addEventListener("touchstart", touch);
  document.addEventListener("touchmove", touch);
  document.addEventListener("touchend", touch);

  function withCenter(boundingBox) {
    boundingBox.centerX = (boundingBox.left + boundingBox.right) / 2;
    boundingBox.centerY = (boundingBox.top + boundingBox.bottom) / 2;
    boundingBox.centerToString = `${boundingBox.centerX}px ${boundingBox.centerY}px`;
    return boundingBox;
  }

  const TRANSFORMATION = 1;
  const MAX_RADIUS = 25;
  const FOLLOW_SPEED = 0.001;

  function getTransformation(x, y, box) {
    const nx = x - box.centerX;
    const ny = y - box.centerY;

    const distance = Math.hypot(nx, ny);
    const radius = Math.min(distance * TRANSFORMATION, MAX_RADIUS);
    const safeDistance = distance || 1;
    const tx = (nx / safeDistance) * radius;
    const ty = (ny / safeDistance) * radius;

    return `translate(${tx}px, ${ty}px)`;
  }

  function changeEyesPosition(x, y) {
    if (isUpdatingEyes) return;
    isUpdatingEyes = true;

    requestAnimationFrame(() => {
      if (eyeLeft) {
        const leftRect = eyeLeft.getBoundingClientRect();
        eyeLeft.style.transform = getTransformation(x, y, withCenter(leftRect));
      }
      if (eyeRight) {
        const rightRect = eyeRight.getBoundingClientRect();
        eyeRight.style.transform = getTransformation(
          x,
          y,
          withCenter(rightRect),
        );
      }
      isUpdatingEyes = false;
    });
  }

  function followCursor() {
    if (!mascotContainer) {
      return;
    }

    const mascotRect = mascotContainer.getBoundingClientRect();
    const mascotCenterX = mascotRect.left + mascotRect.width / 2;
    const mascotCenterY = mascotRect.top + mascotRect.height / 2;

    const dx = mouseX - mascotCenterX;
    const dy = mouseY - mascotCenterY;

    // Super slow following towards cursor
    targetOffsetX += dx * FOLLOW_SPEED;
    targetOffsetY += dy * FOLLOW_SPEED;

    // Update mascot position
    mascotContainer.style.setProperty(
      "--mascot-offset-x",
      `${targetOffsetX}px`,
    );
    mascotContainer.style.setProperty(
      "--mascot-offset-y",
      `${targetOffsetY}px`,
    );

    requestAnimationFrame(followCursor);
  }

  function setFrontLook() {
    if (!eyeLeft || !eyeRight) {
      return;
    }

    eyeLeft.style.transform = FRONT_LOOK_TRANSFORM_LEFT;
    eyeRight.style.transform = FRONT_LOOK_TRANSFORM_RIGHT;
  }

  if (mustacheGroup) {
    mustacheGroup.addEventListener("mouseenter", () => {
      isMunching = true;
      eatCounter++;
      setFrontLook();
      const eatEvent = new CustomEvent("mascotEatsCursor", {
        detail: { count: eatCounter },
      });
      document.dispatchEvent(eatEvent);
    });

    mustacheGroup.addEventListener("mouseleave", () => {
      isMunching = false;
      changeEyesPosition(mouseX, mouseY);
    });
  }

  changeEyesPosition(mouseX, mouseY);
  followCursor();
</script>
